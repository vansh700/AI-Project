ENVIRONMENT=development
PORT=8000

# PostgreSQL — MS2 owns this database exclusively
MS2_DB_URL=postgresql+asyncpg://ms2_user:ms2_password@localhost:5433/ms2_db

# Neo4j — used for repository knowledge graph
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Redis — used to consume jobs from BullMQ
REDIS_URL=redis://localhost:6379

# MS1 webhook target — MS2 posts completion events here only
MS1_WEBHOOK_URL=http://localhost:3000/webhooks

# Webhook secret shared with MS1 for request verification
WEBHOOK_SECRET=change_me_in_production

# OpenAI — used by the LangGraph AI planner (optional; mock plan used if unset)
OPENAI_API_KEY=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

