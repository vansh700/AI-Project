NODE_ENV=development
PORT=3000

# PostgreSQL — MS1 owns this database
MS1_DB_URL=postgresql://ms1_user:ms1_password@localhost:5432/ms1_db

# Redis — used for BullMQ queue dispatch
REDIS_URL=redis://localhost:6379

# JWT — change before deploying
JWT_SECRET=change_me_in_production

# MS2 internal URL — never exposed to frontend
MS2_INTERNAL_URL=http://localhost:8000

# Webhook secret shared with MS2 for webhook verification
WEBHOOK_SECRET=change_me_in_production
